# Foto-Scan (Gemini). Key von https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: alternativer Variablenname (von Google-Dokumentation)
# GOOGLE_GENERATIVE_AI_API_KEY=

GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_MODEL_FALLBACKS=gemini-2.0-flash,gemini-2.5-flash

# Max. Upload-Größe in MB (große Handyfotos). Danach shrinked der Server per sharp.
GEMINI_MAX_UPLOAD_MB=40

# Optional: Bildverkleinerung (defaults reichen meist)
# SHRINK_MAX_EDGE_PX=2048
# SHRINK_TARGET_BYTES=4194304
# SHRINK_SKIP_BELOW_BYTES=1228800

PORT=8787
